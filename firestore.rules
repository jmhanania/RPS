rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────────

    function isLeaderboard(col) {
      return col in ['v2_leaderboard_0', 'v2_leaderboard_1', 'v2_leaderboard_2',
                     'v2_leaderboard_3', 'v2_leaderboard_4'];
    }

    function isNonNegInt(v) {
      return v is int && v >= 0;
    }

    function isValidEntry(data) {
      return isNonNegInt(data.wins)
          && isNonNegInt(data.losses)
          && isNonNegInt(data.ties)
          && isNonNegInt(data.rock)
          && isNonNegInt(data.paper)
          && isNonNegInt(data.scissors)
          && !('email' in data);
    }

    // ── Usernames ─────────────────────────────────────────────────────────────
    // Each document ID is a lowercased handle; value is { uid } of the owner.
    // Enforces global uniqueness — claimed atomically via client transaction.

    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null
                   && request.resource.data.keys().hasOnly(['uid'])
                   && request.resource.data.uid == request.auth.uid;
      allow update: if request.auth != null
                   && resource.data.uid == request.auth.uid
                   && request.resource.data.keys().hasOnly(['uid'])
                   && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
                   && resource.data.uid == request.auth.uid;
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    // Each document stores { username: string } for one authenticated user.

    match /users/{userId} {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.data.keys().hasOnly(['username'])
                   && request.resource.data.username is string
                   && request.resource.data.username.size() >= 2
                   && request.resource.data.username.size() <= 24;
    }

    // ── Leaderboard ───────────────────────────────────────────────────────────

    match /{collection}/{userId} {
      allow read:  if isLeaderboard(collection);
      allow write: if isLeaderboard(collection)
                   && request.auth != null
                   && request.auth.uid == userId
                   && isValidEntry(request.resource.data);
    }
  }
}
